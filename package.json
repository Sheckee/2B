{
  "name": "obsidian-ai-agent-2b",
  "version": "0.1.0",
  "description": "Offline Claude-style AI agent for Obsidian Mobile - completely local, no APIs",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "dev": "node esbuild.config.js",
    "build": "tsc && node esbuild.config.js production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern='.unit.'",
    "test:integration": "jest --testPathPattern='.integration.'",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist esbuild.out.*",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "llm",
    "claude",
    "offline",
    "mobile",
    "rag",
    "local"
  ],
  "author": "Sheckee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sheckee/2B.git"
  },
  "bugs": {
    "url": "https://github.com/Sheckee/2B/issues"
  },
  "homepage": "https://github.com/Sheckee/2B",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "obsidian": "^1.5.0",
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/collab": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/search": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@lezer/common": "^1.0.0",
    "@lezer/highlight": "^1.0.0",
    "@lezer/lr": "^1.0.0",
    "events": "^3.3.0"
  },
  "optionalDependencies": {
    "vosk": "^0.3.32",
    "@objectbox/core": "^3.0.0",
    "sentence-transformers": "^2.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
